# OpenCode Go 多模型交叉验证 —— 安装时唯一需要改的文件
#
# 用法：
#   1. 复制本文件为同目录下的 opencode.env
#        cp config/opencode.env.example config/opencode.env
#   2. 把下面的占位符替换成你在 https://opencode.ai/auth 订阅 Go 后拿到的密钥
#   3. 之后任何核验前 source 一次即可： source config/opencode.env
#
# 注意：opencode.env 不要提交到 git（已在 .gitignore 忽略）。

export OPENCODE_API_KEY="把你的_OpenCode_Go_密钥粘贴到这里"
